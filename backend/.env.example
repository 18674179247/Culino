# 运行环境（dev / production）
RUN_MODE=dev

# 数据库连接字符串
DATABASE_URL=postgres://user:password@localhost:5432/culino_db

# JWT 签名密钥（长度至少 32 字节，生成: openssl rand -base64 48）
JWT_SECRET=dev-jwt-secret-change-me-at-least-32-bytes-long-xxxxxxxxxxxx

# 服务监听地址
SERVER_ADDR=0.0.0.0:3000

# CORS 允许的 Origin（逗号分隔，留空则允许所有，仅开发环境使用）
# Web 前端开发服务器(./gradlew :app:wasmJsBrowserDevelopmentRun 默认 8080)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Redis 连接地址
REDIS_URL=redis://127.0.0.1:6379

# 日志级别（trace / debug / info / warn / error）
LOG_LEVEL=debug

# 日志文件目录
LOG_DIR=logs

# S3 兼容对象存储（RustFS/MinIO）
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=culino
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# DeepSeek API Key（用于 AI 功能）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 启动时自动提权为管理员的用户名（仅当该用户已注册时生效）
# 初次使用：留空启动 -> 用该用户名注册 -> 填入此变量 -> 重启
BOOTSTRAP_ADMIN_USERNAME=
