# ==========================================================================
# Culino 生产环境配置模板
#
# 使用方式：
#   cp .env.prod.example .env.prod
#   vi .env.prod   # 填入实际值
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# 警告：.env.prod 含敏感凭据，务必加入 .gitignore，切勿提交到版本库
# ==========================================================================

# ---------- 数据持久化 ----------
# 宿主机数据根目录，所有持久化数据会挂载在此
# 部署前执行: sudo mkdir -p /data/culino/{pgdata,redisdata,rustfsdata,logs}
#             sudo chown -R $(id -u):$(id -g) /data/culino
DATA_ROOT=/data/culino

# ---------- 镜像（方案 B：拉取预构建镜像时使用）----------
IMAGE_REGISTRY=your-registry.example.com
IMAGE_TAG=latest

# ---------- PostgreSQL ----------
POSTGRES_USER=culino
POSTGRES_DB=culino_db
# 生成强密码: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ---------- Redis ----------
# 生成强密码: openssl rand -base64 24
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ---------- 应用核心 ----------
# JWT 签名密钥。生产环境必须随机生成且长度≥32 字节
# 生成: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# CORS 允许的源，多个用逗号分隔。生产必须填正式域名，不要用 localhost 或 *
CORS_ORIGINS=https://your-domain.com

# 日志级别：trace / debug / info / warn / error
LOG_LEVEL=info

# ---------- S3 兼容对象存储（RustFS）----------
# 生成: openssl rand -hex 16   (access key)
#       openssl rand -base64 32 (secret key)
# 切勿使用默认的 minioadmin/minioadmin
S3_ACCESS_KEY=REPLACE_WITH_ACCESS_KEY
S3_SECRET_KEY=REPLACE_WITH_SECRET_KEY
S3_REGION=us-east-1
S3_BUCKET=culino

# ---------- DeepSeek AI ----------
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-REPLACE_WITH_YOUR_KEY

# ---------- 管理员引导 ----------
# 启动时自动提权为管理员的用户名（仅当该用户已注册时生效）
# 初次部署流程:
#   1. 此项留空启动
#   2. 用你希望成为管理员的用户名注册（通过 /api/v1/user/register）
#   3. 填入此变量
#   4. 重启应用 -> 自动提权
BOOTSTRAP_ADMIN_USERNAME=
